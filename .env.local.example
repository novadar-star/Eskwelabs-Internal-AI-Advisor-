# ─────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Must match the redirect URI registered in Google Cloud Console
# In development: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────
# Google OAuth2 (from Google Cloud Console)
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# Safe to expose to the browser — used in client-side Supabase calls
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key — safe to expose, but RLS must be configured
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — SERVER ONLY, never expose to the browser
# Used for admin operations that bypass RLS (e.g., allow-list checks)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────────
# LLM Providers (server-side only — never prefix with NEXT_PUBLIC_)
# ─────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key

# ─────────────────────────────────────────────
# Google Docs API (service account — server-side only)
# ─────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Private key from service account JSON — newlines as \n
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-key-here\n-----END RSA PRIVATE KEY-----"

# Google Doc IDs (from the document URL)
DNA_DOC_ID=your-dna-google-doc-id
ADVISOR_1_PROMPT_DOC_ID=your-data-dashboard-advisor-doc-id
ADVISOR_2_PROMPT_DOC_ID=your-ssot-memo-advisor-doc-id
ADVISOR_3_PROMPT_DOC_ID=your-advisor-3-doc-id
